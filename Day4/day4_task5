#include <stdio.h>

#define MAX 10

enum Status {
    NEVOJITET_PUNE = 1,
    MESATAR,
    SHKELQYESHEM
};

struct Student {
    int id;
    char name[30];
    float progress;
    enum Status status;
};

// SHFAQ STUDENT
void showStudent(struct Student *s) {
    printf("\n----------------------\n");
    printf("ID: %d\n", s->id);
    printf("Emri: %s\n", s->name);
    printf("Progresi: %.2f\n", s->progress);

    if (s->status == NEVOJITET_PUNE)
        printf("Status: Nevojitet pune\n");
    else if (s->status == MESATAR)
        printf("Status: Mesatar\n");
    else
        printf("Status: Shkelqyeshem\n");
}

// FUNKSION POINTER – PËRDITËSIM
void updateProgress(struct Student *s) {
    float newProgress;

    printf("Shkruani progresin e ri (0-100): ");
    scanf("%f", &newProgress);

    if (newProgress < 0 || newProgress > 100) {
        printf("Progres i pavlefshem!\n");
        return;
    }

    s->progress = newProgress;

    if (newProgress < 50)
        s->status = NEVOJITET_PUNE;
    else if (newProgress < 80)
        s->status = MESATAR;
    else
        s->status = SHKELQYESHEM;

    printf("Progresi u perditesua me sukses!\n");
}

int main() {
    struct Student students[MAX];
    int count = 0;
    int choice;

    do {
        printf("\n===== MENU =====\n");
        printf("1. Shto student\n");
        printf("2. Shfaq studentet\n");
        printf("3. Perditeso progres\n");
        printf("4. Dil\n");
        printf("Zgjedhja: ");
        scanf("%d", &choice);

        if (choice < 1 || choice > 4) {
            printf("Zgjedhje e pavlefshme!\n");
            continue;
        }

        switch(choice) {

            case 1:
                if (count >= MAX) {
                    printf("Kapaciteti eshte i mbushur!\n");
                    break;
                }

                printf("ID: ");
                scanf("%d", &students[count].id);

                // kontroll ID ekzistues
                int exists = 0;
                for (int i = 0; i < count; i++) {
                    if (students[i].id == students[count].id) {
                        exists = 1;
                        break;
                    }
                }

                if (exists) {
                    printf("Ky ID ekziston!\n");
                    break;
                }

                printf("Emri: ");
                scanf("%s", students[count].name);

                printf("Progresi (0-100): ");
                scanf("%f", &students[count].progress);

                if (students[count].progress < 0 || students[count].progress > 100) {
                    printf("Progres i pavlefshem!\n");
                    break;
                }

                if (students[count].progress < 50)
                    students[count].status = NEVOJITET_PUNE;
                else if (students[count].progress < 80)
                    students[count].status = MESATAR;
                else
                    students[count].status = SHKELQYESHEM;

                count++;
                printf("Studenti u shtua me sukses!\n");
                break;

            case 2:
                if (count == 0) {
                    printf("Nuk ka te dhena!\n");
                } else {
                    for (int i = 0; i < count; i++) {
                        showStudent(&students[i]);
                    }
                }
                break;

            case 3: {
                if (count == 0) {
                    printf("Nuk ka studente!\n");
                    break;
                }

                int idSearch;
                printf("Shkruani ID e studentit: ");
                scanf("%d", &idSearch);

                int found = 0;

                for (int i = 0; i < count; i++) {
                    if (students[i].id == idSearch) {
                        updateProgress(&students[i]);
                        found = 1;
                        break;
                    }
                }

                if (!found) {
                    printf("Studenti nuk u gjet!\n");
                }

                break;
            }

            case 4:
                printf("Duke dale...\n");
                break;
        }

    } while (choice != 4);

    return 0;
}
